{
  "name": "groot-ui",
  "version": "0.0.1",
  "packageManager": "npm@11.12.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "registry:build": "npm run registry:build --workspace=packages/ui",
    "registry:index": "tsx scripts/build-registry-index.ts",
    "registry:previews": "tsx scripts/build-preview-registry.ts",
    "registry": "npm run registry:build && npm run registry:index && npm run registry:previews",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.1.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "lenis": "^1.3.21"
  }
}
